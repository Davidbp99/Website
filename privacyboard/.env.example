#!/bin/bash
# Example .env file for PrivacyBoard
# Copy this to .env and update values

# ── DATABASE CONFIGURATION ── #
# Options: mysql, pgsql, sqlite

# MySQL Example
# DB_TYPE=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=privacyboard_db
# DB_USER=root
# DB_PASS=your_mysql_password

# PostgreSQL Example (uncomment to use)
# DB_TYPE=pgsql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=privacyboard_db
# DB_USER=postgres
# DB_PASS=your_postgres_password

# SQLite Example (uncomment to use - good for development)
DB_TYPE=sqlite
DB_PATH=./privacyboard.db

# ── AUTHENTICATION ── #
# Leave empty to disable authentication
# Otherwise, all requests must include this Bearer token in Authorization header
# IMPORTANT: Use a strong random token in production (generate with: openssl rand -hex 32)

AUTH_TOKEN=Bearer my-secret-token

# ── RATE LIMITING ── #
# Prevent abuse by limiting requests per IP or token
# Recommended: 100-500 requests per 60 seconds

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ── CORS ── #
# Which origins are allowed to access this API
# Use * for development, specific origin for production (e.g., https://yourdomain.com)

CORS_ORIGIN=*
